# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Service URLs (used by Pipeline Controller) ─────────────────
LOG_ANALYZER_URL=http://localhost:5001/api/v1/analyze
LOG_ANALYZER_HEALTH_URL=http://localhost:5001/api/v1/health
RECOVERY_SERVICE_URL=http://localhost:6001/recover
NOTIFICATION_SERVICE_URL=http://localhost:7000/notify

# ── Jenkins ────────────────────────────────────────────────────
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=paste_your_jenkins_api_token_here

# ── Security ───────────────────────────────────────────────────
STATUS_API_KEY=any_random_string_you_choose
ALLOWED_LOG_HOSTS=localhost,jenkins

# ── Email notifications (optional) ─────────────────────────────
EMAIL_ENABLED=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_TO=recipient@gmail.com

# ── Slack notifications (optional) ─────────────────────────────
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
